# Database
DATABASE_URL=postgresql+asyncpg://nocturn:nocturn@localhost:5432/nocturn
DATABASE_ECHO=True
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14
MAX_SESSIONS_PER_USER=5

# RouterAI
ROUTERAI_API_KEY=example-routerai-key
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
ROUTERAI_LLM_MODEL=example-llm-model
ROUTERAI_LLM_CONTEXT_WINDOW=8192
ROUTERAI_FETCH_MODEL_CONTEXT_WINDOW=false
ROUTERAI_EXECUTOR_MODEL=example-executor-model
ROUTERAI_EMBEDDING_MODEL=example-embedding-model

# Email
EMAIL_PROVIDER=resend
EMAIL_API_KEY=example-api-key
EMAIL_FROM=noreply@nocturn.example.com

# Admin seed (first launch)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123
ADMIN_NICKNAME=admin


FRONTEND_URL=http://localhost   
BACKEND_API_URL=http://localhost


# Verification & reset
EMAIL_CONFIRM_TTL_HOURS=2
PASSWORD_RESET_TTL_HOURS=1
UNCONFIRMED_ACCOUNT_TTL_HOURS=24

# Notes
MAX_NOTES_PER_USER=3000
MAX_NOTE_SIZE=20000
MAX_TITLE_LENGTH=200
MAX_TAGS_PER_NOTE=10
TRASH_RETENTION_DAYS=30
AUTOSAVE_INTERVAL_SECONDS=5

# Tags
MAX_TAGS_PER_USER=100

# AI assistant
MAX_MESSAGE_LENGTH=4000
MAX_SOURCES_PER_RESPONSE=5
MAX_CHAT_SESSIONS_PER_USER=50
CHAT_SESSION_TTL_DAYS=14
LLM_FIRST_TOKEN_TIMEOUT_SECONDS=10
MAX_NOTES_IN_BULK=25
MAX_ATTACHED_NOTES=10
MAX_MESSAGES_IN_CONTEXT=25
SYSTEM_PROMPT_TOKENS=500
SAFETY_MARGIN_TOKENS=500
PLANNER_CHARS_PER_TOKEN=1.3

# Embedding queue
EMBEDDING_MAX_ATTEMPTS=3
EMBEDDING_DEBOUNCE_MINUTES=2

# Worker
EMBEDDING_QUEUE_INTERVAL_SECONDS=30
CLEANUP_INTERVAL_SECONDS=3600

# Rate limiting
RATE_AUTH_PER_MINUTE=20
RATE_EMAIL_OPS_PER_MINUTE=5
RATE_VERIFY_PER_MINUTE=5
RATE_REFRESH_PER_MINUTE=15
RATE_CRUD_PER_MINUTE=120
RATE_AI_PER_MINUTE=15

# Chunking
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
EMBEDDING_DIMENSIONS=2560