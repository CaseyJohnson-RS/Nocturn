---
title: "Frontend — Page & Route Map"
---
flowchart TD
    Entry(["Браузер открывает URL"])

    Entry --> Root["RootLayout\nПытается обновить токен\n(authApi.refresh → authApi.me)"]

    Root -->|"/ или неизвестный путь"| RedirectApp["→ /app"]
    Root -->|"/app"| CheckAuth{{"Пользователь\nавторизован?"}}
    Root -->|"/auth/*"| CheckGuest{{"Пользователь\nавторизован?"}}
    Root -->|"/auth/confirm-email"| ConfirmEmailPage["ConfirmEmailPage\n🔓 публичный"]
    Root -->|"/auth/reset-password"| ResetPasswordPage["ResetPasswordPage\n🔓 публичный"]

    CheckAuth -->|"нет"| RedirectLogin["→ /auth/login"]
    CheckAuth -->|"да"| AppShell

    CheckGuest -->|"да"| RedirectApp2["→ /app"]
    CheckGuest -->|"нет"| AuthPages

    subgraph AuthPages["Страницы аутентификации"]
        LoginPage["/auth/login\nLoginPage"]
        RegisterPage["/auth/register\nRegisterPage"]
        ForgotPasswordPage["/auth/forgot-password\nForgotPasswordPage"]
    end

    LoginPage -->|"успешный логин"| AppShell
    RegisterPage -->|"регистрация"| LoginPage
    ForgotPasswordPage -->|"письмо отправлено"| LoginPage
    ConfirmEmailPage -->|"подтверждён"| LoginPage
    ResetPasswordPage -->|"пароль изменён"| LoginPage

    subgraph AppShell["/app — AppShell (SPA, без перезагрузки)"]
        direction TB

        subgraph Panels["Панели (через Sidebar → uiStore)"]
            PanelNotes["panel:notes\nNoteList"]
            PanelSearch["panel:search\nSearchPanel"]
            PanelTags["panel:tags\nTagsPanel"]
            PanelTrash["panel:trash\nTrashPanel"]
            PanelAdmin["panel:admin\nAdminPanel\n(только admin)"]
        end

        subgraph Tabs["Вкладки (tabbar)"]
            TabNote["note:{id}\nNoteEditor"]
        end

        ChatPanel["ChatPanel\n(overlay справа,\nесли chatOpen)"]
        ProfilePopup["ProfilePopup\n(overlay,\nесли profileOpen)"]
    end

    PanelNotes -->|"клик на заметку"| TabNote
    PanelSearch -->|"результат"| TabNote
    PanelTrash -->|"восстановить"| PanelNotes

    AppShell -->|"выйти из аккаунта"| LoginPage
