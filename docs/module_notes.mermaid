---
title: "Module: Notes"
---
classDiagram
    direction TB

    class Note {
        +UUID user_id
        +str title
        +str content
        +int version
        +datetime deleted_at
    }
    class Tag {
        <<external: tags>>
    }
    class NoteTag {
        <<join table>>
        +UUID note_id
        +UUID tag_id
    }
    class TagsRepository {
        <<external: tags>>
    }
    class RAGService {
        <<external: rag>>
    }
    class NotesRepository {
        +create_note()
        +list_notes()
        +update_note()
        +soft_delete_note()
        +search_by_keywords()
    }
    class NotesService {
        +create()
        +list()
        +update()
        +soft_delete() / restore()
        +search_keywords()
    }

    Note "1" --> "*" NoteTag
    NoteTag "*" --> "1" Tag
    NotesRepository ..> Note
    NotesService --> NotesRepository
    NotesService --> TagsRepository
    NotesService --> RAGService
