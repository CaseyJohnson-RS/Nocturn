---
title: "Notes — Create, Update, Soft Delete & Restore"
---
sequenceDiagram
    actor Client
    participant Router
    participant NotesService
    participant NotesRepository
    participant TagsRepository
    participant RAGService
    participant DB

    %% ── Create Note ───────────────────────────────────────────
    Client->>Router: POST /notes {title, content, tag_ids}
    Router->>NotesService: create(user_id, title, content, tag_ids)

    NotesService->>NotesRepository: count_user_notes(user_id)
    NotesRepository->>DB: SELECT COUNT notes
    DB-->>NotesRepository: count

    alt limit reached
        NotesService-->>Router: 409 ConflictError
        Router-->>Client: 409 Conflict
    else within limit
        opt tag_ids provided
            NotesService->>TagsRepository: verify_tags_belong_to_user(user_id, tag_ids)
            TagsRepository->>DB: SELECT tags
            DB-->>TagsRepository: found tags
        end

        NotesService->>NotesService: sanitize(title, content)
        NotesService->>NotesRepository: create_note(user_id, title, content)
        NotesRepository->>DB: INSERT notes
        DB-->>NotesRepository: note

        opt tag_ids provided
            NotesService->>NotesRepository: set_note_tags(note_id, tag_ids)
            NotesRepository->>DB: INSERT note_tags
        end

        NotesService->>RAGService: index_note(note)
        RAGService->>DB: INSERT/UPDATE embedding_queue

        NotesService-->>Router: NoteResponse
        Router-->>Client: 201 Created
    end

    %% ── Update Note ───────────────────────────────────────────
    Client->>Router: PATCH /notes/{id} {version, title?, content?}
    Router->>NotesService: update(user_id, note_id, version, title, content)

    NotesService->>NotesRepository: get_active_note(note_id, user_id)
    NotesRepository->>DB: SELECT notes WHERE deleted_at IS NULL
    DB-->>NotesRepository: note | None

    alt note not found
        NotesService-->>Router: 404 NotFoundError
    else version mismatch
        NotesService-->>Router: 409 ConflictError
    else ok
        NotesService->>NotesRepository: update_note(note, title, content)
        NotesRepository->>DB: UPDATE notes SET version=version+1
        NotesService->>RAGService: index_note(note)
        RAGService->>DB: INSERT/UPDATE embedding_queue
        NotesService-->>Router: NoteResponse
        Router-->>Client: 200 OK
    end

    %% ── Soft Delete & Restore ─────────────────────────────────
    Client->>Router: DELETE /notes/{id}
    Router->>NotesService: soft_delete(user_id, note_id)
    NotesService->>NotesRepository: get_active_note(note_id, user_id)
    NotesRepository->>DB: SELECT notes
    DB-->>NotesRepository: note
    NotesService->>NotesRepository: soft_delete_note(note, now)
    NotesRepository->>DB: UPDATE notes SET deleted_at=now
    NotesService->>RAGService: remove_note(note_id)
    RAGService->>DB: DELETE note_chunks + DELETE embedding_queue
    Router-->>Client: 204 No Content

    Client->>Router: POST /notes/{id}/restore
    Router->>NotesService: restore(user_id, note_id)
    NotesService->>NotesRepository: get_deleted_note(note_id, user_id)
    NotesRepository->>DB: SELECT notes WHERE deleted_at IS NOT NULL
    DB-->>NotesRepository: note
    NotesService->>NotesRepository: restore_note(note)
    NotesRepository->>DB: UPDATE notes SET deleted_at=NULL
    NotesService->>RAGService: index_note(note)
    RAGService->>DB: INSERT/UPDATE embedding_queue
    NotesService-->>Router: NoteResponse
    Router-->>Client: 200 OK
