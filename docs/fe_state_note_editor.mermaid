---
title: "Frontend — NoteEditor State Machine"
---
stateDiagram-v2
    [*] --> Loading : открыть вкладку note:[id]

    state Loading {
        [*] --> FetchNote : GET /api/notes/[id]
        FetchNote --> [*] : данные получены
        FetchNote --> Error404 : 404 заметка не найдена
    }

    Loading --> Clean : заметка загружена
    Loading --> [*] : Error404 — закрыть вкладку

    state Clean {
        [*] --> Idle
    }

    note right of Clean
        Заголовок и тег-строка
        отображают актуальные данные.
        TabDot не показывается.
    end note

    Clean --> Dirty : пользователь изменил заголовок / контент / теги

    state Dirty {
        [*] --> Debouncing
        Debouncing --> Debouncing : новый ввод сбрасывает таймер (500 мс)
    }

    state Saving {
        [*] --> PatchRequest
        PatchRequest --> [*] : 200 OK — версия обновлена
        PatchRequest --> ConflictDetected : 409 Conflict
        PatchRequest --> SaveFailed : сетевая ошибка / 5xx
    }

    Dirty --> Saving : дебаунс истёк — PATCH /api/notes/[id]
    Saving --> Clean : 200 — данные синхронизированы
    Saving --> Conflict : 409 — версия на сервере новее
    Saving --> Dirty : SaveFailed — показать тост, повторить попытку

    state Conflict {
        [*] --> ShowBanner
        ShowBanner --> MergeChoice
        MergeChoice --> KeepLocal : пользователь выбрал "Оставить моё"
        MergeChoice --> AcceptRemote : пользователь выбрал "Принять сервер"
    }

    Conflict --> Dirty : KeepLocal → force-save с актуальной версией
    Conflict --> Clean : AcceptRemote → перезагрузить заметку

    Clean --> ProposalPending : chatStore получил ai:proposal для этой заметки
    Dirty --> ProposalPending : то же, пока редактируется

    state ProposalPending {
        [*] --> ShowProposalCard
        ShowProposalCard --> Applying : пользователь нажал Apply
        ShowProposalCard --> [*] : пользователь нажал Dismiss
    }

    note right of ProposalPending
        TabDot = proposal
        ProposalCard в ChatPanel.
    end note

    ProposalPending --> Dirty : Applying → применить diff → автосохранение
    ProposalPending --> Clean : Dismiss — убрать карточку, TabDot сбросить

    Clean --> [*] : вкладка закрыта
    Dirty --> [*] : вкладка закрыта (несохранённые изменения сохраняются принудительно)