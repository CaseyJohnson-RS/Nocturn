---
title: "Frontend — Auth Session Lifecycle"
---
stateDiagram-v2
    [*] --> Loading : браузер открывает приложение

    state Loading {
        [*] --> RefreshToken : authApi.refresh()
        RefreshToken --> FetchMe : 200 OK (новый accessToken)
        RefreshToken --> [*] : 401 — токена нет / истёк
        FetchMe --> [*] : возвращает User
    }

    Loading --> Authenticated : refresh + me успешны
    Loading --> Guest : refresh вернул 401

    state Guest {
        [*] --> LoginPage
        LoginPage --> Registering : перейти на /auth/register
        LoginPage --> ForgotPassword : ссылка «Забыли пароль?»
        Registering --> AwaitingConfirm : POST /api/auth/register → 201
        AwaitingConfirm --> LoginPage : email подтверждён (/auth/confirm-email)
        ForgotPassword --> LoginPage : письмо отправлено
        LoginPage --> LoggingIn : POST /api/auth/login
        LoggingIn --> LoginPage : 401 неверные данные
    }

    Guest --> Authenticated : LoggingIn → 200 (accessToken + refreshToken set)

    state Authenticated {
        [*] --> Active
        Active --> Active : пользователь работает в приложении
    }

    Authenticated --> Refreshing : запрос вернул 401 (accessToken истёк)

    state Refreshing {
        [*] --> AttemptRefresh : authApi.refresh()
        AttemptRefresh --> Success : 200 новый токен
        AttemptRefresh --> Fail : 401 refreshToken истёк
    }

    Refreshing --> Authenticated : Success — повторить исходный запрос
    Refreshing --> Guest : Fail — очистить authStore → /auth/login

    Authenticated --> LoggingOut : пользователь нажал «Выйти»

    state LoggingOut {
        [*] --> RevokeToken : POST /api/auth/logout
        RevokeToken --> Cleared : очистить authStore + cookies
    }

    LoggingOut --> Guest : Cleared → редирект /auth/login

    note right of Refreshing
        Очередь запросов приостанавливается.
        После Success все запросы повторяются
        с новым токеном.
    end note
