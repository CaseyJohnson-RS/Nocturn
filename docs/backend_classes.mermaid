classDiagram
    direction TB

    %% ── DB MODELS ──────────────────────────────────────

    class User {
        +UUID id
        +str email
        +str nickname
        +str role
        +bool is_active
    }
    class RefreshToken {
        +UUID user_id
        +datetime expires_at
    }
    class VerificationToken {
        +UUID user_id
        +str type
        +datetime expires_at
    }
    class Note {
        +UUID user_id
        +str title
        +str content
        +int version
        +datetime deleted_at
    }
    class Tag {
        +UUID user_id
        +str name
    }
    class NoteChunk {
        +UUID note_id
        +int chunk_index
        +Vector embedding
    }
    class EmbeddingTask {
        +UUID note_id
        +str status
        +int attempts
    }
    class ChatSession {
        +UUID user_id
        +str title
        +datetime last_message_at
    }
    class ChatMessage {
        +UUID session_id
        +str role
        +str content
        +list attached_note_ids
    }

    %% ── REPOSITORIES ───────────────────────────────────

    class AuthRepository {
        <<Repository>>
        +get_user_by_email()
        +create_user()
        +create_refresh_token()
        +create_verification_token()
    }
    class NotesRepository {
        <<Repository>>
        +create_note()
        +list_notes()
        +update_note()
        +soft_delete_note()
    }
    class TagsRepository {
        <<Repository>>
        +create_tag()
        +list_tags()
        +verify_tags_belong_to_user()
    }
    class RAGRepository {
        <<Repository>>
        +upsert_chunks()
        +search_similar()
        +upsert_embedding_task()
    }
    class AIRepository {
        <<Repository>>
        +create_session()
        +add_message()
        +list_sessions()
    }
    class AdminRepository {
        <<Repository>>
        +list_users()
        +set_active()
        +set_role()
    }

    %% ── SERVICES ───────────────────────────────────────

    class AuthService {
        <<Service>>
        +register()
        +login()
        +refresh()
        +reset_password()
    }
    class NotesService {
        <<Service>>
        +create()
        +list()
        +update()
        +soft_delete() / restore()
    }
    class TagsService {
        <<Service>>
        +create()
        +list()
        +update()
        +delete()
    }
    class RAGService {
        <<Service>>
        +index_note()
        +remove_note()
        +search()
    }
    class AIService {
        <<Service>>
        +create_session()
        +chat_stream()
        +list_sessions()
    }
    class AdminService {
        <<Service>>
        +list_users()
        +set_active()
        +set_role()
    }
    class ProfileService {
        <<Service>>
        +update_nickname()
        +change_password()
    }

    %% ── EXCEPTIONS ─────────────────────────────────────

    class HTTPException { <<external>> }
    class NotFoundError { 404 }
    class ConflictError { 409 }
    class ValidationError { 400 }
    class ForbiddenError { 403 }
    class UnauthorizedError { 401 }

    NotFoundError --|> HTTPException
    ConflictError --|> HTTPException
    ValidationError --|> HTTPException
    ForbiddenError --|> HTTPException
    UnauthorizedError --|> HTTPException

    %% ── DB RELATIONS ───────────────────────────────────

    User "1" --> "*" RefreshToken
    User "1" --> "*" VerificationToken
    User "1" --> "*" Note
    User "1" --> "*" Tag
    User "1" --> "*" ChatSession
    Note "*" --> "*" Tag : NoteTag
    Note "1" --> "*" NoteChunk
    Note "1" --> "0..1" EmbeddingTask
    ChatSession "1" --> "*" ChatMessage

    %% ── SERVICE → REPOSITORY ───────────────────────────

    AuthService --> AuthRepository
    NotesService --> NotesRepository
    NotesService --> TagsRepository
    NotesService --> RAGService
    TagsService --> TagsRepository
    RAGService --> RAGRepository
    AIService --> AIRepository
    AIService --> RAGService
    AdminService --> AdminRepository
    ProfileService --> AuthRepository

    %% ── REPOSITORY → MODEL ─────────────────────────────

    AuthRepository ..> User
    AuthRepository ..> RefreshToken
    AuthRepository ..> VerificationToken
    NotesRepository ..> Note
    TagsRepository ..> Tag
    RAGRepository ..> NoteChunk
    RAGRepository ..> EmbeddingTask
    AIRepository ..> ChatSession
    AIRepository ..> ChatMessage
    AdminRepository ..> User
