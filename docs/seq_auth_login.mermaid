---
title: "Auth — Login & Token Refresh"
---
sequenceDiagram
    actor Client
    participant Router
    participant AuthService
    participant AuthRepository
    participant DB

    %% ── Login ─────────────────────────────────────────────────
    Client->>Router: POST /auth/login {email, password}
    Router->>AuthService: login(email, password)

    AuthService->>AuthRepository: get_user_by_email(email)
    AuthRepository->>DB: SELECT users
    DB-->>AuthRepository: user | None

    alt user not found
        AuthService-->>Router: 401 UnauthorizedError
    else user found
        AuthService->>AuthService: ph.verify(password_hash, password)

        alt wrong password / email not confirmed / inactive
            AuthService-->>Router: 401 UnauthorizedError
        else credentials valid
            AuthService->>AuthRepository: count_user_sessions(user_id)
            AuthRepository->>DB: SELECT refresh_tokens WHERE expires_at > now
            DB-->>AuthRepository: count

            alt session limit reached
                AuthService-->>Router: 409 ConflictError
            else within limit
                AuthService->>AuthService: create_access_token(user_id, role)
                AuthService->>AuthRepository: create_refresh_token(user_id, hash, exp)
                AuthRepository->>DB: INSERT refresh_tokens

                AuthService-->>Router: (TokenResponse, refresh_token)
                Router-->>Client: 200 {access_token} + Set-Cookie: refresh_token
            end
        end
    end

    %% ── Token Refresh ─────────────────────────────────────────
    Client->>Router: POST /auth/refresh (cookie: refresh_token)
    Router->>AuthService: refresh(raw_refresh_token)

    AuthService->>AuthRepository: get_refresh_token_by_hash(hash)
    AuthRepository->>DB: SELECT refresh_tokens
    DB-->>AuthRepository: token | None

    alt token not found or expired
        AuthService-->>Router: 401 UnauthorizedError
        Router-->>Client: 401 Unauthorized
    else token valid
        AuthService->>AuthRepository: get_user_by_id(user_id)
        AuthRepository->>DB: SELECT users
        DB-->>AuthRepository: user

        AuthService->>AuthRepository: delete_refresh_token(old_token_id)
        AuthRepository->>DB: DELETE refresh_tokens

        AuthService->>AuthRepository: create_refresh_token(user_id, new_hash, exp)
        AuthRepository->>DB: INSERT refresh_tokens

        AuthService->>AuthService: create_access_token(user_id, role)
        AuthService-->>Router: (TokenResponse, new_refresh_token)
        Router-->>Client: 200 {access_token} + Set-Cookie: refresh_token (rotated)
    end
